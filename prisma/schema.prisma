generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id             String      @id
  class          String
  gender         String
  hp             Int         @default(100)
  mp             Int         @default(50)
  maxHP          Int         @default(100)
  maxMP          Int         @default(50)
  skin           String      @default("default")
  points         Int         @default(0)
  stars          Int         @default(0)
  strength       Int         @default(0)
  dexterity      Int         @default(0)
  intelligence   Int         @default(0)
  lucky          Int         @default(0)
  items          Item[]
  equipments     Equipment[]
  equippedShield String?
  equippedWeapon String?
  mapId          Int         @default(1)
  mapPositionX   Int         @default(0)
  mapPositionY   Int         @default(0)
}

model Equipment {
  id         String  @unique @default(cuid())
  name       String
  damage     Int?
  protection Int?
  Player     Player? @relation(fields: [playerId], references: [id])
  playerId   String?

  @@unique([playerId, name])
}

model Item {
  id       String  @unique @default(cuid())
  name     String
  type     String  @default("item")
  count    Int
  Player   Player? @relation(fields: [playerId], references: [id])
  playerId String?

  @@unique([playerId, name])
}
